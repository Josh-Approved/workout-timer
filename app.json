{
  "expo": {
    "name": "Free-Workout-Timer",
    "slug": "Free-Workout-Timer",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.freeworkouttimer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b7035cd5-9963-4268-b22f-2c77ef1045e3"
      }
    },
    "owner": "josh-approved",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b7035cd5-9963-4268-b22f-2c77ef1045e3"
    },
    "plugins": [
      "expo-audio",
      "expo-font"
    ]
  }
}
