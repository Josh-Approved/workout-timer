######################################################################
# state-survival.yaml — the T4 chaos-net "process death + state survival" flow
#
# THIS IS A REFERENCE PATTERN, NOT A HAND-EDITED FILE. Like mobile.yaml, an
# app's real qa/flows/state-survival.yaml is GENERATED by
# scripts/qa/compile-flow.mjs from a `survival` block in qa/journey.json. Author
# the block, never the yaml:
#
#   {
#     "appId": "com.joshapproved.<app>",
#     "steps": [ ... the screenshot / Tier-2 journey ... ],
#     "survival": {
#       "$comment": "why this mutation, what the oracle proves",
#       "steps": [
#         // 1. MUTATE — perform the app's core write (add an item, log a
#         //    contact, create a record). Prove it landed:
#         { "assertNot": "@marker" },      // it wasn't there before
#         { "tap": "@add" }, { "type": "…" }, { "pressKey": "Enter" },
#         { "assert": "@marker" },         // it's there now
#         { "wait": 1500 },                // let the durable write flush to disk
#
#         // 2. KILL — REAL system-initiated process death. On Android this is
#         //    an actual process kill (the "OS reclaimed a backgrounded app
#         //    mid-write" regime); on iOS it aliases to stopApp (no true
#         //    force-kill via the XCTest driver). One verb, both platforms:
#         { "killApp": true },
#
#         // 3. RELAUNCH keeping state (a cold JS restart; nav resets to the
#         //    initial route, so RE-NAVIGATE back to where the marker shows):
#         { "relaunch": true },
#         { "waitFor": "@home", "timeout": 30000 },
#         { "tap": "@list" },
#
#         // 4. ASSERT SURVIVED — an INTENT oracle, not a pixel. The marker the
#         //    user created before the crash is still there afterwards.
#         { "assert": "@marker" }
#       ]
#     }
#   }
#
# WHY A SEPARATE FILE FROM mobile.yaml: this flow kills and relaunches the app,
# so it is slow and belongs in the FULL profile + nightly, NOT the per-PR gate
# (qa-e2e.yml runs only mobile.yaml). Keeping it a distinct artifact is what
# keeps it off the per-PR critical path. It is run by
# scripts/qa/run-survival.mjs (which T5's nightly engine schedules).
#
# The `killApp` verb compiles to a platform-branched runFlow (below) so the
# single YAML does the right thing on each OS:
#
#   # killApp: real process death on Android; stopApp alias on iOS
#   - runFlow:
#       when:
#         platform: Android
#       commands:
#         - killApp
#   - runFlow:
#       when:
#         platform: iOS
#       commands:
#         - stopApp
#
# See runbooks/testing-net.md § chaos net and stack/maestro.md § killApp.
######################################################################
